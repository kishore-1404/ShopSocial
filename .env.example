# Example environment file for ShopSocial
# Copy to .env and edit values as needed

# PostgreSQL database settings
POSTGRES_DB=shopsocial
POSTGRES_USER=shopsocial
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=db
POSTGRES_PORT=5432

# JWT secret for all services
SERVICE_JWT_SECRET=changeme

# Redis settings (if needed by services)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Django settings (user service)
# DJANGO_SETTINGS_MODULE=userservice.settings

# Add any other service-specific environment variables below
# ...
